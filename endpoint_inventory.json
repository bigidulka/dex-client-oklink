    ["GET", "/api/explorer/v2/{chain}/block/transactions", "block transactions fallback"],
    ["GET", "/api/explorer/v1/{chain}/transactionsNoRestrict", "UTXO/no-restrict transactions"],
    ["GET", "/api/explorer/v2/{chain}/blocks/tokenTransfers", "block token transfers"],
