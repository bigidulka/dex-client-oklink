    ["GET", "/api/explorer/v2/{chain}/tokens/{address}", "token metadata"],
    ["GET", "/api/explorer/v2/{chain}/addresses/{address}/transactionsByClassfy/condition", "address transactions"],
    ["GET", "/api/explorer/v1/{chain}/addresses/{address}/internalTx/condition", "address internal transactions"],
    ["GET", "/api/explorer/v2/{chain}/addresses/{address}/transfers/condition/token", "address token transfers"],
    ["GET", "/api/explorer/v1/{chain_slug}/transactions?type=pending", "pending transactions"],
    ["GET", "/priapi/v1/lite/evm/block/detail/transactions", "lite EVM block transactions"]
