    ["GET", "/api/explorer/v2/{chain}/block/{height}/transfers/condition/nft", "block NFT transfers"],
    ["GET", "/api/explorer/v2/{chain}/blocks/internalTransactions", "block internal transactions"],
    ["GET", "/api/explorer/v2/{chain}/block/internalTransactions", "block internal transactions fallback"],
    ["GET", "/api/explorer/v2/{chain}/blocks/event", "block contract events"],
    ["GET", "/api/explorer/v2/{chain}/blocks/message", "block messages"],
